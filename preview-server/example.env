# Preview Server Environment Variables
# Copy this file to .env and fill in the values:
#   cp example.env .env

# ── Container Images ────────────────────────────────────────────────────────
# CI sets these to GHCR tags. Leave empty to build from source with --build.
PREVIEW_IMAGE=
AUTH_IMAGE=

# ── Strapi CMS ──────────────────────────────────────────────────────────────
# URL of the Strapi instance (must be reachable from the containers)
GATSBY_STRAPI_API_URL=https://cms.example.com

# Strapi API token (needs draft-content read access)
STRAPI_TOKEN=

# ── Gatsby ──────────────────────────────────────────────────────────────────
# Token to protect the /__refresh webhook endpoint
GATSBY_REFRESH_TOKEN=

# Mapbox API key for clinic map components
GATSBY_MAPBOX_API_KEY=

# Base URL for serverless API endpoints
GATSBY_API_BASE_URL=https://api.example.com

# ── Caddy / TLS ────────────────────────────────────────────────────────────
# Domain name for the preview site
PREVIEW_DOMAIN=preview.aascmed.com

# Path to directory containing cert.pem and key.pem (Cloudflare origin cert)
PREVIEW_CERTS_PATH=/home/preview-deploy/certs

# Host ports (change if 443/80 are already in use)
PREVIEW_HTTPS_PORT=443
PREVIEW_HTTP_PORT=80
